{
  "kind": "collectionType",
  "collectionName": "amenities",
  "info": {
    "singularName": "amenity",
    "pluralName": "amenities",
    "displayName": "Catalog - Project - Amenities",
    "description": "Shared property catalog: Amenities available in real estate projects (Swimming Pool, Gym, Parking, etc.)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "uid",
      "targetField": "name",
      "required": false
    },
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "recreation",
        "wellness",
        "leisure",
        "outdoor",
        "business",
        "technology",
        "residential",
        "parking",
        "security",
        "sustainability",
        "convenience",
        "luxury",
        "other"
      ]
    },
    "projects": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::project.project",
      "mappedBy": "amenities"
    }
  }
}
