{
  "kind": "collectionType",
  "collectionName": "blocks",
  "info": {
    "singularName": "block",
    "pluralName": "blocks",
    "displayName": "• Blocks",
    "description": "Individual blocks within a real estate project (phase + tower + sector)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "project": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project.project",
      "inversedBy": "blocks"
    },
    "code": {
      "type": "uid",
      "targetField": "name",
      "required": false
    },
    "name": {
      "type": "string",
      "required": false
    },
    "legacyId": {
      "type": "string"
    },
    "phase": {
      "type": "string"
    },
    "tower": {
      "type": "string"
    },
    "sector": {
      "type": "string"
    },
    "year": {
      "type": "integer",
      "required": true
    },
    "quarter": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "T1",
        "T2",
        "T3",
        "T4",
        "S1",
        "S2"
      ]
    },
    "collectionDate": {
      "type": "date"
    },
    "blockCategory": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::block-category.block-category"
    },
    "blockFocus": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::block-focus.block-focus"
    },
    "blockStatus": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::block-status.block-status"
    },
    "market": {
      "type": "enumeration",
      "required": false,
      "enum": [
        "Primary",
        "Secondary"
      ]
    },
    "startDate": {
      "type": "date"
    },
    "deliveryDate": {
      "type": "date"
    },
    "commercializationMonths": {
      "type": "integer"
    },
    "totalUnits": {
      "type": "integer",
      "pluginOptions": {
        "content-manager": {
          "editable": false
        }
      }
    },
    "totalM2": {
      "type": "decimal",
      "pluginOptions": {
        "content-manager": {
          "editable": false
        }
      }
    },
    "availableUnits": {
      "type": "integer",
      "pluginOptions": {
        "content-manager": {
          "editable": false
        }
      }
    },
    "availableM2": {
      "type": "decimal",
      "pluginOptions": {
        "content-manager": {
          "editable": false
        }
      }
    },
    "averagePriceUSD": {
      "type": "decimal",
      "pluginOptions": {
        "content-manager": {
          "editable": false
        }
      }
    },
    "averageSizeM2": {
      "type": "decimal",
      "pluginOptions": {
        "content-manager": {
          "editable": false
        }
      }
    },
    "averagePricePerM2USD": {
      "type": "decimal",
      "pluginOptions": {
        "content-manager": {
          "editable": false
        }
      }
    },
    "averageInstallmentUSD": {
      "type": "decimal",
      "pluginOptions": {
        "content-manager": {
          "editable": false
        }
      }
    },
    "averageIncomeUSD": {
      "type": "decimal",
      "pluginOptions": {
        "content-manager": {
          "editable": false
        }
      }
    },
    "additionalParkingPriceUSD": {
      "type": "decimal"
    },
    "visitorParking": {
      "type": "integer"
    },
    "assignedParking": {
      "type": "integer"
    },
    "totalProjectParking": {
      "type": "integer",
      "default": 0
    },
    "migNumber": {
      "type": "integer",
      "default": 0
    }
  }
}
