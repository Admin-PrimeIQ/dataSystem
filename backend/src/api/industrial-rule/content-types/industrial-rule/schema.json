{
  "kind": "collectionType",
  "collectionName": "industrial_rules",
  "info": {
    "singularName": "industrial-rule",
    "pluralName": "industrial-rules",
    "displayName": "Z - TBD - Industrial Rule",
    "description": "Business rules for industrial units (min warehouse height, loading area size)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "maxLength": 100,
      "required": true
    },
    "description": {
      "type": "text"
    },
    "ruleType": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "warehouse_height",
        "loading_area",
        "power_capacity",
        "access_requirements",
        "zoning",
        "other"
      ]
    },
    "minWarehouseHeight": {
      "type": "decimal",
      "min": 0
    },
    "maxWarehouseHeight": {
      "type": "decimal",
      "min": 0
    },
    "minLoadingAreaSize": {
      "type": "decimal",
      "min": 0
    },
    "maxLoadingAreaSize": {
      "type": "decimal",
      "min": 0
    },
    "minLoadingDocks": {
      "type": "integer",
      "min": 0
    },
    "maxLoadingDocks": {
      "type": "integer",
      "min": 0
    },
    "minPowerCapacity": {
      "type": "decimal",
      "min": 0
    },
    "maxPowerCapacity": {
      "type": "decimal",
      "min": 0
    },
    "powerUnit": {
      "type": "enumeration",
      "default": "kW",
      "enum": [
        "kW",
        "kVA",
        "HP"
      ]
    },
    "truckAccessRequired": {
      "type": "boolean",
      "default": false
    },
    "railAccessRequired": {
      "type": "boolean",
      "default": false
    },
    "waterSupplyRequired": {
      "type": "boolean",
      "default": false
    },
    "sewageSystemRequired": {
      "type": "boolean",
      "default": false
    },
    "fireSuppressionRequired": {
      "type": "boolean",
      "default": false
    },
    "securitySystemRequired": {
      "type": "boolean",
      "default": false
    },
    "minOfficeSpace": {
      "type": "decimal",
      "min": 0
    },
    "maxOfficeSpace": {
      "type": "decimal",
      "min": 0
    },
    "minStorageCapacity": {
      "type": "decimal",
      "min": 0
    },
    "maxStorageCapacity": {
      "type": "decimal",
      "min": 0
    },
    "allowedZoning": {
      "type": "json"
    },
    "restrictedZoning": {
      "type": "json"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "effectiveDate": {
      "type": "date"
    },
    "expirationDate": {
      "type": "date"
    },
    "priority": {
      "type": "integer",
      "default": 0
    }
  }
}
