{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "• Projects",
    "description": "Real estate projects"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "developer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::developer.developer"
    },
    "country": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::country.country"
    },
    "department": {
      "type": "string"
    },
    "municipality": {
      "type": "string"
    },
    "zone": {
      "type": "string"
    },
    "subzone": {
      "type": "string"
    },
    "latitude": {
      "type": "decimal",
      "precision": 10,
      "scale": 8
    },
    "longitude": {
      "type": "decimal",
      "precision": 10,
      "scale": 8
    },
    "market": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Primary",
        "Secondary"
      ]
    },
    "nse": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::nse.nse"
    },
    "securityType": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::security-type.security-type"
    },
    "muvi": {
      "type": "boolean",
      "default": false
    },
    "showroom": {
      "type": "boolean",
      "default": false
    },
    "modelHouse": {
      "type": "boolean",
      "default": false
    },
    "accessQuantity": {
      "type": "integer"
    },
    "imageUrl": {
      "type": "string"
    },
    "fha": {
      "type": "boolean",
      "default": false
    },
    "fractionalDownPayment": {
      "type": "boolean",
      "default": false
    },
    "downPaymentPercentage": {
      "type": "decimal",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "fractionalDownPayment"
            },
            true
          ]
        }
      },
      "min": 0,
      "max": 100
    },
    "amenities": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::amenity.amenity",
      "inversedBy": "projects"
    },
    "services": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::service.service",
      "mappedBy": "projects"
    }
  }
}
