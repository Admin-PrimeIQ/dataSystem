{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Projects",
    "description": "Real estate development projects"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "maxLength": 200,
      "required": true
    },
    "code": {
      "type": "string",
      "maxLength": 20,
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "categoryId": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::ref-category.ref-category",
      "description": "Project category (residential, commercial, industrial, etc.)"
    },
    "developer": {
      "type": "string",
      "maxLength": 200,
      "required": true
    },
    "location": {
      "type": "json"
    },
    "startDate": {
      "type": "date"
    },
    "deliveryDate": {
      "type": "date"
    },
    "launchDate": {
      "type": "date"
    },
    "totals": {
      "type": "json"
    },
    "projectFinancingParam": {
      "type": "json"
    },
    "projectSegmentRule": {
      "type": "json"
    },
    "projectAmenity": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::ref-amenity.ref-amenity",
      "description": "Available project amenities (pool, gym, park, etc.)"
    },
    "projectService": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::ref-service.ref-service",
      "description": "Services included in the project (concierge, security, maintenance, etc.)"
    },
    "projectBankShare": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::ref-bank.ref-bank",
      "description": "Banks associated with the project for financing"
    },
    "availability": {
      "type": "enumeration",
      "default": "planning",
      "enum": [
        "planning",
        "development",
        "marketing",
        "construction",
        "completed",
        "cancelled"
      ]
    },
    "isActive": {
      "type": "boolean",
      "default": true
    }
  }
}
