{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Projects",
    "description": "Real estate projects"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "developer": {
      "type": "string"
    },
    "country": {
      "type": "enumeration",
      "required": true,
      "default": "GTM",
      "enum": [
        "GTM",
        "SLV",
        "HND"
      ]
    },
    "department": {
      "type": "string"
    },
    "municipality": {
      "type": "string"
    },
    "zone": {
      "type": "string"
    },
    "subzone": {
      "type": "string"
    },
    "latitude": {
      "type": "decimal"
    },
    "longitude": {
      "type": "decimal"
    },
    "market": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Primary",
        "Secondary"
      ]
    },
    "nseProject": {
      "type": "enumeration",
      "enum": [
        "A_PLUS",
        "A",
        "A_MINUS",
        "B_PLUS",
        "B",
        "B_MINUS",
        "C_PLUS",
        "C",
        "C_MINUS",
        "D"
      ]
    },
    "securityType": {
      "type": "enumeration",
      "enum": [
        "None",
        "Access System",
        "Combined",
        "Own",
        "Private",
        "No"
      ]
    },
    "muvi": {
      "type": "boolean",
      "default": false
    },
    "showroom": {
      "type": "boolean",
      "default": false
    },
    "modelHouse": {
      "type": "boolean",
      "default": false
    },
    "accessQuantity": {
      "type": "integer"
    },
    "imageUrl": {
      "type": "string"
    },
    "fha": {
      "type": "boolean",
      "default": false
    },
    "fractionalDownPayment": {
      "type": "boolean",
      "default": false
    },
    "downPaymentPercentage": {
      "type": "decimal",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "fractionalDownPayment"
            },
            true
          ]
        }
      },
      "min": 0,
      "max": 100
    }
  }
}
