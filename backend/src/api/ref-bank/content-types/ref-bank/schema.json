{
  "kind": "collectionType",
  "collectionName": "ref_banks",
  "info": {
    "singularName": "ref-bank",
    "pluralName": "ref-banks",
    "displayName": "Reference Bank",
    "description": "Bank references (BAC, BAM, Banrural, etc.)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 100
    },
    "code": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 10
    },
    "swiftCode": {
      "type": "string",
      "maxLength": 11
    },
    "country": {
      "type": "string",
      "maxLength": 50,
      "default": "Guatemala"
    },
    "website": {
      "type": "string",
      "maxLength": 255
    },
    "phone": {
      "type": "string",
      "maxLength": 20
    },
    "address": {
      "type": "text"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
