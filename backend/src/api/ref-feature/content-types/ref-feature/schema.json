{
  "kind": "collectionType",
  "collectionName": "ref_features",
  "info": {
    "singularName": "ref-feature",
    "pluralName": "ref-features",
    "displayName": "Reference Feature",
    "description": "Flexible attributes for Project/Unit features"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 100
    },
    "description": {
      "type": "text"
    },
    "code": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 20
    },
    "dataType": {
      "type": "enumeration",
      "enum": ["string", "number", "boolean", "date", "text", "json"],
      "required": true,
      "default": "string"
    },
    "isRequired": {
      "type": "boolean",
      "default": false
    },
    "defaultValue": {
      "type": "text"
    },
    "validationRules": {
      "type": "json"
    },
    "appliesTo": {
      "type": "enumeration",
      "enum": ["project", "unit", "both"],
      "required": true,
      "default": "both"
    },
    "category": {
      "type": "string",
      "maxLength": 50
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
