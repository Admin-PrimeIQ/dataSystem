{
  "kind": "collectionType",
  "collectionName": "ref_services",
  "info": {
    "singularName": "ref-service",
    "pluralName": "ref-services",
    "displayName": "Projects - Service",
    "description": "Property services (Water, Power Plant, Security, etc.)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "maxLength": 100,
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "serviceType": {
      "type": "enumeration",
      "default": "other",
      "enum": [
        "utility",
        "security",
        "maintenance",
        "administrative",
        "other"
      ]
    },
    "isEssential": {
      "type": "boolean",
      "default": false
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
