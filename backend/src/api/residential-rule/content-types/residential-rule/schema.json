{
  "kind": "collectionType",
  "collectionName": "residential_rules",
  "info": {
    "singularName": "residential-rule",
    "pluralName": "residential-rules",
    "displayName": "Residential Rule",
    "description": "Business rules for residential units (min/max price per m²)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 100
    },
    "description": {
      "type": "text"
    },
    "ruleType": {
      "type": "enumeration",
      "enum": ["pricing", "area", "bedrooms", "bathrooms", "location", "other"],
      "required": true
    },
    "minPricePerSqm": {
      "type": "decimal",
      "min": 0
    },
    "maxPricePerSqm": {
      "type": "decimal",
      "min": 0
    },
    "minArea": {
      "type": "decimal",
      "min": 0
    },
    "maxArea": {
      "type": "decimal",
      "min": 0
    },
    "minBedrooms": {
      "type": "integer",
      "min": 0
    },
    "maxBedrooms": {
      "type": "integer",
      "min": 0
    },
    "minBathrooms": {
      "type": "integer",
      "min": 0
    },
    "maxBathrooms": {
      "type": "integer",
      "min": 0
    },
    "locationRestrictions": {
      "type": "json"
    },
    "amenityRequirements": {
      "type": "json"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "effectiveDate": {
      "type": "date"
    },
    "expirationDate": {
      "type": "date"
    },
    "priority": {
      "type": "integer",
      "default": 0
    }
  }
}
