{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Catalog - Project - Services",
    "description": "Shared property catalog: Services available in real estate projects (electricity, water, gas, etc.)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "uid",
      "targetField": "name",
      "required": false
    },
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "utility",
        "security",
        "maintenance",
        "administrative",
        "telecommunications",
        "waste",
        "energy",
        "water",
        "gas",
        "internet",
        "cable",
        "other"
      ]
    },
    "projects": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::project.project",
      "inversedBy": "services"
    }
  }
}
