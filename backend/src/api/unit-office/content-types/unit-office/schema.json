{
  "kind": "collectionType",
  "collectionName": "unit_offices",
  "info": {
    "singularName": "unit-office",
    "pluralName": "unit-offices",
    "displayName": "Unit Office",
    "description": "Office unit subtype with class, legends, and employees"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "unit": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::unit.unit"
    },
    "class": {
      "type": "enumeration",
      "enum": ["A", "B", "C", "premium", "standard", "basic"],
      "required": true
    },
    "legends": {
      "type": "json"
    },
    "employees": {
      "type": "integer",
      "min": 0
    },
    "receptionArea": {
      "type": "boolean",
      "default": false
    },
    "meetingRooms": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "privateOffices": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "openSpace": {
      "type": "boolean",
      "default": false
    },
    "kitchenette": {
      "type": "boolean",
      "default": false
    },
    "storageRoom": {
      "type": "boolean",
      "default": false
    },
    "floor": {
      "type": "integer"
    },
    "view": {
      "type": "enumeration",
      "enum": ["city", "park", "street", "courtyard", "none"]
    },
    "airConditioning": {
      "type": "boolean",
      "default": false
    },
    "elevatorAccess": {
      "type": "boolean",
      "default": false
    }
  }
}
