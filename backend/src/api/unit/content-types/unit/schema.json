{
  "kind": "collectionType",
  "collectionName": "units",
  "info": {
    "singularName": "unit",
    "pluralName": "units",
    "displayName": "Units",
    "description": "Generic unit with area, price, rent, and KPIs"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "maxLength": 200,
      "required": true
    },
    "code": {
      "type": "string",
      "maxLength": 20,
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "unitType": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "residential",
        "office",
        "industrial"
      ]
    },
    "area": {
      "type": "decimal",
      "required": true
    },
    "areaUnit": {
      "type": "enumeration",
      "default": "sqm",
      "enum": [
        "sqm",
        "sqft",
        "hectares",
        "acres"
      ]
    },
    "price": {
      "type": "decimal"
    },
    "rent": {
      "type": "decimal"
    },
    "currency": {
      "type": "string",
      "default": "GTQ",
      "maxLength": 3
    },
    "kpis": {
      "type": "json"
    },
    "status": {
      "type": "enumeration",
      "default": "available",
      "enum": [
        "available",
        "reserved",
        "sold",
        "rented",
        "maintenance",
        "inactive"
      ]
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "type": {
      "type": "dynamiczone",
      "components": [
        "unit-types.residential",
        "unit-types.office",
        "unit-types.industrial"
      ]
    }
  }
}
